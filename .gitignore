# Python
__pycache__/
*.py[cod]
.venv/

# Vendored Archipelago checkout (clone separately; see pz_ap_client/README.md)
vendor/

# Client runtime state (idempotency high-water marks)
.client_state/

# AP / OS noise
*.log
.DS_Store

# RE-tool scan caches / state (written by tools/ - all regenerable, never commit).
# NB: tools/.pz_module.bin alone is a ~330 MB dump of the game module.
*.bin
*.npy
*.meta
# dot-prefixed scan caches/baselines (data.json / anchors.json are NOT dot-prefixed, so they're kept)
.*.json

# Test cache
.pytest_cache/

# Archived RE dead-ends - local history only (see tools/_attic/README.md).
# Remove this line instead if you'd rather commit them to preserve the RE journey.
tools/_attic/

# SonarQube local analysis (server lives at D:\sonarqube; see docs/SONARQUBE.md).
# sonar-project.properties IS committed; the scanner work dir + token are not.
.scannerwork/
.sonar-token

# PyInstaller build output (regenerable; see docs/PACKAGING.md).
# pz-ap-client.spec + pz_client_main.py ARE committed (the build recipe); the output is not.
build/
build_stage/
dist/
tools/_decomp/
tools/_research_extract/

# OVL patch workspace: the ~350 MB patched Main.ovl variants and other binaries are
# regenerable (cobra-tools reinject from the pristine ovl); the authored patch sources
# (.lua shells, mechanic-research settings spikes) ARE kept trackable.
tools/_ovl_patch/**
!tools/_ovl_patch/**/
!tools/_ovl_patch/**/*.lua
!tools/_ovl_patch/**/*.mechanicresearchsettings
# ...EXCEPT verbatim/patched Frontier game files - never redistribute (local copies only):
# pristine extracts, the vanilla scenario_01 script copies, and the bytecode-patched
# staff-tab binary (compiled game Lua named .lua).
tools/_ovl_patch/_pristine/
tools/_ovl_patch/_scn1/
tools/_ovl_patch/_scn1src/
tools/_ovl_patch/_verify_scn1/
tools/_ovl_patch/_verify_scn1src/
tools/_ovl_patch/**/editors.park.staffmanagementtab.lua
tools/_ovl_patch/**/database.c0careerdata.lua
tools/_ovl_patch/**/parksettings.scenario_ap_parksettings.lua

# Heap-scan output of tools/_lua_error_scan.py (regenerable from a live game).
tools/_lua_error_hits.txt

# (The ovl_src tree is fully authored as of the v19 additive-content-pack rewrite -
# every module is committed; see pz_ap_client/ovl_src/README.md.)
